NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgres://speakinghub:speakinghub@localhost:5432/speakinghub
DB_POOL_MAX=30
DB_STATEMENT_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=10000

# Security
JWT_SECRET=change-me-super-secret
JWT_EXPIRES_IN=7d

# Admin bootstrap (created on first run if not exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Optional
SERVE_STATIC=true
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW=1 minute

