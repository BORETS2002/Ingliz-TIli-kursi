# ========================================
# Speaking Hub - Admin Panel Configuration
# ========================================
# Copy this file to .env and update all values for your environment

# -------- Server Configuration --------
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

# -------- Database Configuration (REQUIRED) --------
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://speakinghub:speakinghub@localhost:5432/speakinghub
DB_POOL_MAX=30
DB_STATEMENT_TIMEOUT_MS=10000
DB_QUERY_TIMEOUT_MS=10000

# -------- Security & Authentication --------
# JWT Secret - MUST change in production! Generate a strong random string
JWT_SECRET=change-me-super-secret-key-in-production
JWT_EXPIRES_IN=7d

# -------- Admin User Bootstrap --------
# Default admin credentials (created on first run if not exists)
# Run: node scripts/setup-db.js to initialize the database and create admin user
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# -------- Features --------
SERVE_STATIC=true
RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW=1 minute

# Optional: Configure CORS for specific origins
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

